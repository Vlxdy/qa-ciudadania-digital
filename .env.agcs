# ─────────────────────────────────────────────────────────────────────────────
# WEBHOOK
# El runner QA levanta el mismo servidor en este puerto al ejecutar npm run qa.
# ─────────────────────────────────────────────────────────────────────────────
WEBHOOK_PORT=4000
WEBHOOK_SECRET=cambia-este-secreto-por-uno-seguro
# [OPCIONAL]
WEBHOOK_PATH_PREFIX=
WEBHOOK_JWT_ENABLED=true
# Poner en false si no quieres que npm run qa levante el webhook automáticamente
QA_WEBHOOK_ENABLED=true

# Ruta que el servidor aprobador usa al enviar el callback de confirmación
APRO_CALLBACK_PATH=/webhook/aprobador
APRO_CALLBACK_TIMEOUT_MS=55000

# Ruta que el servidor notificador usa para el callback de confirmación (natural)
NOTI_CALLBACK_PATH=/webhook/notificador
NOTI_CALLBACK_TIMEOUT_MS=55000
# [OPCIONAL] Rutas a incluir en webhookCallbacks del response.json — comma-separated.
# Default cuando está vacío: <NOTI_CALLBACK_PATH>,/file
# Ejemplo: /webhook/notificador,/file,/documentos-digitales
NOTI_WEBHOOK_WATCH_PATHS=/webhook/notificador,/file,/documentos-digitales

# Carácter obligatorio legal
NOTI_OBL_LEGAL_CALLBACK_PATH=/webhook/notificador-obligatorio
NOTI_OBL_LEGAL_CALLBACK_TIMEOUT_MS=55000
# [OPCIONAL] Default cuando está vacío: <NOTI_OBL_LEGAL_CALLBACK_PATH>,/file
NOTI_OBL_LEGAL_WEBHOOK_WATCH_PATHS=/webhook/notificador-obligatorio,/file

# Carácter obligatorio requerimiento
NOTI_OBL_REQ_CALLBACK_PATH=/webhook/notificador-requerimiento
NOTI_OBL_REQ_CALLBACK_TIMEOUT_MS=55000
# [OPCIONAL] Default cuando está vacío: <NOTI_OBL_REQ_CALLBACK_PATH>,/file
NOTI_OBL_REQ_WEBHOOK_WATCH_PATHS=/webhook/notificador-requerimiento,/file

