# También se usa como titular en QR-Seguro.
# Sobreescribe individualmente (NOTI_NOTIFICADOR_*, NOTI_AUTORIDAD_*, etc.) solo
# si un escenario requiere una persona distinta para ese rol.
QA_OPERADOR_TIPO_DOC=CIE
QA_OPERADOR_NUMERO_DOC=6508410-3C
QA_OPERADOR_FECHA_NAC=1956-08-22
#22/08/1956

# Credenciales OIDC del operador (debe coincidir con QA_OPERADOR_NUMERO_DOC)
CEDULA_IDENTIDAD=4748807
CONTRASENA=Agepic135

