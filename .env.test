OIDC_CLIENT_ID=BB8_5A1jTNatQAv4WqaWwhDh2TzXqnpAJ5qwnn2cvmC
OIDC_CLIENT_SECRET=NeQ-K3dCnD-8UU6B8b_IHn2p68W0Ayfl2GWhyiO3qC_XwqWoZN8uY4nC_F-xd1tppPUcnxtStSKCdDLKo9ouFw
OIDC_SCOPE=openid profile fecha_nacimiento email celular offline_access 
OIDC_REDIRECT_URI=https://1nnjzj6j-4000.brs.devtunnels.ms/webhook/proveedor
OIDC_POST_LOGOUT_REDIRECT_URI=https://1nnjzj6j-4000.brs.devtunnels.ms/webhook/proveedor

# [OPCIONAL]
OIDC_SESSION=true
OIDC_PROPERTY=user
OIDC_DEFAULT_STRATEGY=oidc
OIDC_AUTH_PATH=/auth
OIDC_TOKEN_PATH=/token
OIDC_CLIENT_AUTH_METHOD=post
OIDC_PROMPT=login
OIDC_USE_PKCE=false
OIDC_TIMEOUT_MS=180000

# [REQUERIDA] Autenticación móvil PKCE — escenarios prov-10/11/12
# Cliente OIDC registrado para apps móviles (sin client_secret, con PKCE S256).

