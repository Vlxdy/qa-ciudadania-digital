OIDC_MOBILE_REDIRECT_URI=bo.gob.nombre-sistema.rpa:/oauth2redirect
OIDC_MOBILE_SCOPE=openid profile fecha_nacimiento email celular me.devices.create me.devices.delete me.sessions.read nonce.read nonce.create offline_access

