## CONFIGURACIÓN DEL NOTIFICADOR
ISSUER_NOTIFICADOR=https://tu-issuer.gob.bo
TOKEN_CONFIGURACION=tu_token_aqui
RSA_PUBLIC_KEY_PATH=./keys/public.pem

RSA_PADDING=PKCS1

USE_FIXED_AES=false
FIXED_AES_KEY_HEX=
FIXED_IV_HEX=

OUTPUT_DIR=./output
AUTO_SEND=false

## CONFIGURACIÓN DEL APROBADOR
APROBADOR_URL=https://aprobador-cd3.dev.agetic.gob.bo
TOKEN_CLIENTE=xxxxx
ACCESS_TOKEN_CIUDADANIA=xxxxx

# 🔥 clave para tu problema actual
HASH_MODE=BUFFER
# o
# HASH_MODE=BASE64

OUTPUT_DIR=./output
## CONFIGURACIÓN OIDC (PROVEEDOR)
OIDC_ISSUER=https://proveedor-cd3.test.agetic.gob.bo
OIDC_CLIENT_ID=tu_client_id
OIDC_CLIENT_SECRET=tu_client_secret
OIDC_SCOPE=openid profile fecha_nacimiento email celular offline_access
OIDC_REDIRECT_URI=https://tu-dominio/login/ciudadania
OIDC_POST_LOGOUT_REDIRECT_URI=https://tu-dominio/login

# Parámetros extra del proveedor (como en tu ejemplo de URL)
OIDC_SESSION=true
OIDC_PROPERTY=user
OIDC_DEFAULT_STRATEGY=oidc

OIDC_AUTH_PATH=/auth
OIDC_TOKEN_PATH=/token
OIDC_CLIENT_AUTH_METHOD=post
# basic | post | mobile
OIDC_PROMPT=login
OIDC_USE_PKCE=false
OIDC_HEADLESS=false
OIDC_TIMEOUT_MS=180000
# PLAYWRIGHT_PACKAGE=playwright

# USUARIO DE PRUEBA DE CIUDADANÍA
CEDULA_IDENTIDAD=12345678
CONTRASENA=tu_contrasena_aqui