## CONFIGURACIÓN DEL NOTIFICADOR
ISSUER_NOTIFICADOR=https://tu-issuer.gob.bo
TOKEN_CONFIGURACION=tu_token_aqui
RSA_PUBLIC_KEY_PATH=./keys/public.pem

RSA_PADDING=PKCS1

USE_FIXED_AES=false
FIXED_AES_KEY_HEX=
FIXED_IV_HEX=

OUTPUT_DIR=./output
AUTO_SEND=false

## CONFIGURACIÓN DEL APROBADOR
APROBADOR_URL=https://aprobador-cd3.dev.agetic.gob.bo
TOKEN_CLIENTE=xxxxx
ACCESS_TOKEN_CIUDADANIA=xxxxx

# 🔥 clave para tu problema actual
HASH_MODE=BUFFER
# o
# HASH_MODE=BASE64

OUTPUT_DIR=./output