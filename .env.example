# ============================================================================
# QA CIUDADANÍA DIGITAL — PLANTILLA DE VARIABLES DE ENTORNO
# ============================================================================
# Convención:
# - [REQUERIDA] Debes definirla para ejecutar el módulo/escenario.
# - [OPCIONAL] Puedes omitirla; se usa default interno.
#
# Consejo:
# - Usa BROWSER_HEADLESS como configuración única para Playwright en todos
#   los módulos (Proveedor, Aprobador y Delegado).
# ============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# GLOBAL
# ─────────────────────────────────────────────────────────────────────────────
OUTPUT_DIR=./output
BROWSER_HEADLESS=true
# [OPCIONAL] Si no se define, cada flujo usa su timeout por defecto.
# BROWSER_TIMEOUT_MS=120000

# [OPCIONAL] Activa logs extra en algunos flujos.
DEBUG=true
# LOG_LEVEL=debug


# ─────────────────────────────────────────────────────────────────────────────
# NOTIFICADOR — CONEXIÓN
# ─────────────────────────────────────────────────────────────────────────────
ISSUER_NOTIFICADOR=https://tu-issuer.gob.bo
TOKEN_CONFIGURACION=tu_token_aqui
RSA_PUBLIC_KEY_PATH=./keys/public.pem

# [OPCIONAL]
RSA_PADDING=PKCS1
USE_FIXED_AES=false
FIXED_AES_KEY_HEX=
FIXED_IV_HEX=
AUTO_SEND=false


# ─────────────────────────────────────────────────────────────────────────────
# NOTIFICADOR — DATOS DE NOTIFICACIÓN (QA)
# ─────────────────────────────────────────────────────────────────────────────
# Estos valores reemplazan casos/notificacion-01.json en escenarios QA.

# Contenido
NOTI_TITULO=Notificación de prueba QA
NOTI_DESCRIPCION=Se notifica al ciudadano sobre el proceso de prueba automatizada.

# Notificador
NOTI_NOTIFICADOR_TIPO_DOC=CI
NOTI_NOTIFICADOR_NUMERO_DOC=4160481
NOTI_NOTIFICADOR_FECHA_NAC=1960-05-26

# Autoridad
NOTI_AUTORIDAD_TIPO_DOC=CI
NOTI_AUTORIDAD_NUMERO_DOC=4160481
NOTI_AUTORIDAD_FECHA_NAC=1960-05-26

# Notificado principal (CI)
NOTI_NOTIFICADO_TIPO_DOC=CI
NOTI_NOTIFICADO_NUMERO_DOC=5585535
NOTI_NOTIFICADO_FECHA_NAC=1974-01-31

# Notificado CIE (extranjero) — escenario noti-20
NOTI_NOTIFICADO_CIE_NUMERO_DOC=E-123456
NOTI_NOTIFICADO_CIE_FECHA_NAC=1985-03-15

# Enlace principal (APROBACION)
NOTI_ENLACE_URL=https://example.com/qa/documento.pdf
NOTI_ENLACE_ETIQUETA=Documento QA
NOTI_ENLACE_TIPO=APROBACION
# [OPCIONAL] Si vacío, se calcula automáticamente.
NOTI_ENLACE_HASH=

# Enlace firma (FIRMA)
NOTI_ENLACE_FIRMA_URL=https://example.com/qa/firmado.pdf
NOTI_ENLACE_FIRMA_ETIQUETA=Documento Firmado QA
# [OPCIONAL] Si vacío, se calcula automáticamente.
NOTI_ENLACE_FIRMA_HASH=

# Formulario
NOTI_FORMULARIO_URL=https://example.com/qa/formulario.pdf
NOTI_FORMULARIO_ETIQUETA=Formulario QA
NOTI_FORMULARIO_TIPO=FIRMA
# [OPCIONAL] Si vacío, se calcula automáticamente.
NOTI_FORMULARIO_HASH=

# [OPCIONAL] Si vacío, usa entidad origen.
NOTI_ENTIDAD_NOTIFICADORA=


# ─────────────────────────────────────────────────────────────────────────────
# NOTIFICADOR — CARÁCTER OBLIGATORIO LEGAL (escenario noti-21)
# ─────────────────────────────────────────────────────────────────────────────
# [REQUERIDA] para ejecutar noti-21. Configuración separada del carácter opcional.
ISSUER_NOTIFICADOR_OBL_LEGAL=https://tu-issuer-obl-legal.gob.bo
TOKEN_CONFIGURACION_OBL_LEGAL=tu_token_obl_legal_aqui


# ─────────────────────────────────────────────────────────────────────────────
# NOTIFICADOR — CARÁCTER OBLIGATORIO REQUERIMIENTO (escenario noti-22)
# ─────────────────────────────────────────────────────────────────────────────
# [REQUERIDA] para ejecutar noti-22. Configuración separada del carácter opcional.
ISSUER_NOTIFICADOR_OBL_REQ=https://tu-issuer-obl-req.gob.bo
TOKEN_CONFIGURACION_OBL_REQ=tu_token_obl_req_aqui


# ─────────────────────────────────────────────────────────────────────────────
# NOTIFICADOR JURÍDICO / DELEGADO
# ─────────────────────────────────────────────────────────────────────────────
# Jurídico
NOTI_JURIDICO_CODIGO_ENTIDAD=340
# [OPCIONAL] Segunda entidad para juri-20
NOTI_JURIDICO_CODIGO_ENTIDAD_2=341

# Delegado
NOTI_DELEGADO_CODIGO_ENTIDAD=97
NOTI_DELEGADO_DESCRIPCION=Solicitud de delegación de buzón de entidad para pruebas QA.
NOTI_DELEGADO_REPRESENTANTE_TIPO_DOC=CI
NOTI_DELEGADO_REPRESENTANTE_NUMERO_DOC=7644262
NOTI_DELEGADO_REPRESENTANTE_FECHA_NAC=1990-01-15

# [OPCIONAL] Si defines URL, se intenta aprobación automática en portal.
DELEGADO_APPROVAL_URL_BASE=
# [OPCIONAL] Legacy: usa BROWSER_HEADLESS como preferido.
DELEGADO_APPROVAL_HEADLESS=
# [OPCIONAL]
DELEGADO_APPROVAL_TIMEOUT_MS=120000


# ─────────────────────────────────────────────────────────────────────────────
# APROBADOR
# ─────────────────────────────────────────────────────────────────────────────
APROBADOR_URL=https://aprobador-cd3.dev.agetic.gob.bo
TOKEN_CLIENTE=xxxxx
ACCESS_TOKEN_CIUDADANIA=xxxxx

# [OPCIONAL] BUFFER | BASE64
HASH_MODE=BUFFER

# [OPCIONAL] Listener Playwright
APROBACION_RESULT_ENDPOINT=/api/solicitudes
APROBACION_SUCCESS_PATTERN="\"aprobado\":true"
APROBACION_WAIT_TIMEOUT_MS=120000
# [OPCIONAL] Legacy: usa BROWSER_HEADLESS como preferido.
APROBACION_HEADLESS=


# ─────────────────────────────────────────────────────────────────────────────
# PROVEEDOR OIDC
# ─────────────────────────────────────────────────────────────────────────────
OIDC_ISSUER=https://proveedor-cd3.test.agetic.gob.bo
OIDC_CLIENT_ID=tu_client_id
OIDC_CLIENT_SECRET=tu_client_secret
OIDC_SCOPE=openid profile fecha_nacimiento email celular offline_access
OIDC_REDIRECT_URI=https://tu-dominio/login/ciudadania
OIDC_POST_LOGOUT_REDIRECT_URI=https://tu-dominio/login

# [OPCIONAL]
OIDC_SESSION=true
OIDC_PROPERTY=user
OIDC_DEFAULT_STRATEGY=oidc
OIDC_AUTH_PATH=/auth
OIDC_TOKEN_PATH=/token
OIDC_CLIENT_AUTH_METHOD=post
OIDC_PROMPT=login
OIDC_USE_PKCE=false
OIDC_TIMEOUT_MS=180000
# [OPCIONAL] Legacy: usa BROWSER_HEADLESS como preferido.
OIDC_HEADLESS=

# Credenciales QA de ciudadanía
CEDULA_IDENTIDAD=12345678
CONTRASENA=tu_contrasena_aqui


# ─────────────────────────────────────────────────────────────────────────────
# PROVEEDOR OIDC — AUTENTICACIÓN MÓVIL (PKCE) (escenarios prov-10/11/12)
# ─────────────────────────────────────────────────────────────────────────────
# Cliente OIDC registrado para apps móviles (sin client_secret, con PKCE S256).
# [REQUERIDA] para ejecutar escenarios prov-10, prov-11 y prov-12.
OIDC_MOBILE_CLIENT_ID=tu_mobile_client_id
OIDC_MOBILE_REDIRECT_URI=http://localhost:3001/callback

# [OPCIONAL] Scopes para el cliente móvil. Si se omite, usa OIDC_SCOPE.
# OIDC_MOBILE_SCOPE=openid profile


# ─────────────────────────────────────────────────────────────────────────────
# WEBHOOK
# ─────────────────────────────────────────────────────────────────────────────
WEBHOOK_PORT=4000
WEBHOOK_SECRET=cambia-este-secreto-por-uno-seguro
# [OPCIONAL]
WEBHOOK_PATH_PREFIX=
WEBHOOK_JWT_ENABLED=true


# ─────────────────────────────────────────────────────────────────────────────
# AVISOS (escenarios avis-*)
# ─────────────────────────────────────────────────────────────────────────────
AVISOS_URL_BASE=https://<URL_BASE_AVISOS>
AVISOS_TOKEN=<token_plantilla>
AVISOS_CODIGO_PLANTILLA=<uuid_plantilla>
AVISOS_UUID_CIUDADANO=<uuid_ciudadano>
# [OPCIONAL] Para envío múltiple (avis-02)
AVISOS_UUID_CIUDADANO_2=<uuid_ciudadano_2>
# [OPCIONAL]
AVISOS_PARAMETRO_1=Ciudadano QA
AVISOS_PARAMETRO_REDIRECCION=tramite/qa-test


# ─────────────────────────────────────────────────────────────────────────────
# QR-SEGURO (escenarios qrsg-*)
# ─────────────────────────────────────────────────────────────────────────────
QR_SEGURO_URL_BASE=https://<URL_BASE_QR_SEGURO>
QR_SEGURO_TOKEN=<token_proyecto_developer>
QR_SEGURO_CODIGO_DOCUMENTO=R20-2024-000124QA
QR_SEGURO_NOMBRE_DOCUMENTO=Certificado QA de Prueba
QR_SEGURO_DESCRIPCION_DOCUMENTO=Documento generado por el runner QA.
QR_SEGURO_TITULAR_NOMBRE=CIUDADANO QA
QR_SEGURO_TITULAR_TIPO_DOC=CI
QR_SEGURO_TITULAR_NUMERO_DOC=12345678
QR_SEGURO_TITULAR_ROL=NATURAL


# ─────────────────────────────────────────────────────────────────────────────
# DOCUMENTOS DIGITALES (escenarios nonce-*)
# ─────────────────────────────────────────────────────────────────────────────
DOC_DIGITAL_URL_BASE=https://<URL_BASE_DOCUMENTOS_DIGITALES>
DOC_DIGITAL_TOKEN=<token_proyecto_developer>
# [REQUERIDA] UUID del documento digital creado en Developer (para escenarios gen-nonce-*)
DOC_DIGITAL_CODIGO_DOCUMENTO=<uuid_documento_digital>


# ─────────────────────────────────────────────────────────────────────────────
# FIXTURES QA (OPCIONALES)
# ─────────────────────────────────────────────────────────────────────────────
QA_FIXTURE_VALID_PDF_PATH=
QA_FIXTURE_SIGNED_PDF_PATH=
QA_FIXTURE_VALID_PDF_1MB_PATH=
QA_FIXTURE_VALID_PDF_20MB_PATH=
QA_FIXTURE_EMPTY_PDF_PATH=
QA_FIXTURE_CORRUPTED_PDF_PATH=
QA_FIXTURE_TXT_PATH=
QA_FIXTURE_DOCX_PATH=
QA_FIXTURE_PNG_PATH=
QA_FIXTURE_VALID_JSON_PATH=
QA_FIXTURE_INVALID_PEM_PATH=
