## CONFIGURACIÓN DEL NOTIFICADOR — CONEXIÓN
ISSUER_NOTIFICADOR=https://tu-issuer.gob.bo
TOKEN_CONFIGURACION=tu_token_aqui
RSA_PUBLIC_KEY_PATH=./keys/public.pem

RSA_PADDING=PKCS1

USE_FIXED_AES=false
FIXED_AES_KEY_HEX=
FIXED_IV_HEX=

OUTPUT_DIR=./output
AUTO_SEND=false

## CONFIGURACIÓN DEL NOTIFICADOR — DATOS DE LA NOTIFICACIÓN (QA)
# Estos valores reemplazan el archivo casos/notificacion-01.json en los escenarios QA.
# Si una variable no está definida, se usan datos de ejemplo (placeholder) que
# permiten ejecutar los escenarios de validación local pero fallarán en el servidor real.

# Contenido de la notificación
NOTI_TITULO=Notificación de prueba QA
NOTI_DESCRIPCION=Se notifica al ciudadano sobre el proceso de prueba automatizada.

# Ciudadano que envía la notificación (notificador)
NOTI_NOTIFICADOR_TIPO_DOC=CI
NOTI_NOTIFICADOR_NUMERO_DOC=4160481
NOTI_NOTIFICADOR_FECHA_NAC=1960-05-26

# Ciudadano que representa la autoridad
NOTI_AUTORIDAD_TIPO_DOC=CI
NOTI_AUTORIDAD_NUMERO_DOC=4160481
NOTI_AUTORIDAD_FECHA_NAC=1960-05-26

# Ciudadano notificado principal (CI)
NOTI_NOTIFICADO_TIPO_DOC=CI
NOTI_NOTIFICADO_NUMERO_DOC=5585535
NOTI_NOTIFICADO_FECHA_NAC=1974-01-31

# Ciudadano notificado para escenario CIE (extranjero) — noti-20
NOTI_NOTIFICADO_CIE_NUMERO_DOC=E-123456
NOTI_NOTIFICADO_CIE_FECHA_NAC=1985-03-15

# Enlace adjunto principal (tipo APROBACION — debe ser URL HTTPS que retorne un PDF en BLOB)
NOTI_ENLACE_URL=https://k61xx4rt-4000.brs.devtunnels.ms/file/110_diciembre.pdf
NOTI_ENLACE_ETIQUETA=Documento QA
NOTI_ENLACE_TIPO=APROBACION
# Hash SHA-256 del BLOB del PDF. Si se deja vacío, se calculará descargando el archivo.
NOTI_ENLACE_HASH=

# Enlace para archivo firmado digitalmente (tipo FIRMA) — usado en noti-19 y escenarios mixtos
NOTI_ENLACE_FIRMA_URL=https://k61xx4rt-4000.brs.devtunnels.ms/file/Ejemplo-firmado-firmado.pdf
NOTI_ENLACE_FIRMA_ETIQUETA=Documento Firmado QA
# Hash SHA-256 del BLOB del PDF firmado. Si se deja vacío, se calculará descargando el archivo.
NOTI_ENLACE_FIRMA_HASH=

# Formulario de notificación (debe ser URL HTTPS que retorne un PDF en BLOB)
NOTI_FORMULARIO_URL=https://k61xx4rt-4000.brs.devtunnels.ms/file/Ejemplo-firmado-firmado.pdf
NOTI_FORMULARIO_ETIQUETA=Formulario QA
NOTI_FORMULARIO_TIPO=FIRMA
# Hash SHA-256 del BLOB del PDF. Si se deja vacío, se calculará descargando el archivo.
NOTI_FORMULARIO_HASH=

# Código gob.bo de la entidad notificadora (opcional — dejar vacío para usar entidad origen)
NOTI_ENTIDAD_NOTIFICADORA=

## CONFIGURACIÓN — DELEGADO DE ENTIDAD PÚBLICA (escenarios dele-*)
# Código gob.bo de la entidad para la cual se solicita el delegado
NOTI_DELEGADO_CODIGO_ENTIDAD=97

# Descripción de la solicitud de delegado (máx 600 caracteres)
NOTI_DELEGADO_DESCRIPCION=Solicitud de delegación de buzón de entidad para pruebas QA.

# Ciudadano que recibirá la autorización de delegación (representante legal)
NOTI_DELEGADO_REPRESENTANTE_TIPO_DOC=CI
NOTI_DELEGADO_REPRESENTANTE_NUMERO_DOC=7644262
NOTI_DELEGADO_REPRESENTANTE_FECHA_NAC=1990-01-15

## CONFIGURACIÓN DEL NOTIFICADOR JURÍDICO (entidad pública — endpoint /juridico)
# Código gob.bo de la entidad principal que recibirá la notificación jurídica
NOTI_JURIDICO_CODIGO_ENTIDAD=340

# Código gob.bo de una segunda entidad (para escenario juri-20 — múltiples notificados)
NOTI_JURIDICO_CODIGO_ENTIDAD_2=341

## CONFIGURACIÓN DEL APROBADOR
APROBADOR_URL=https://aprobador-cd3.dev.agetic.gob.bo
TOKEN_CLIENTE=xxxxx
ACCESS_TOKEN_CIUDADANIA=xxxxx

## CONFIGURACIÓN DEL WEBHOOK
# Puerto donde escucha el servidor de webhook
WEBHOOK_PORT=4000
# Secret para firmar y verificar los JWT del webhook
WEBHOOK_SECRET=cambia-este-secreto-por-uno-seguro
# Prefijo de ruta opcional (ej: /api/v1 → /api/v1/webhook/:mecanismo). Dejar vacío para ninguno.
WEBHOOK_PATH_PREFIX=
# Validación JWT: true (default) | false para deshabilitar
WEBHOOK_JWT_ENABLED=true

# 🔥 clave para tu problema actual
HASH_MODE=BUFFER
# o
# HASH_MODE=BASE64

OUTPUT_DIR=./output
## CONFIGURACIÓN OIDC (PROVEEDOR)
OIDC_ISSUER=https://proveedor-cd3.test.agetic.gob.bo
OIDC_CLIENT_ID=tu_client_id
OIDC_CLIENT_SECRET=tu_client_secret
OIDC_SCOPE=openid profile fecha_nacimiento email celular offline_access
OIDC_REDIRECT_URI=https://tu-dominio/login/ciudadania
OIDC_POST_LOGOUT_REDIRECT_URI=https://tu-dominio/login

# Parámetros extra del proveedor (como en tu ejemplo de URL)
OIDC_SESSION=true
OIDC_PROPERTY=user
OIDC_DEFAULT_STRATEGY=oidc

OIDC_AUTH_PATH=/auth
OIDC_TOKEN_PATH=/token
OIDC_CLIENT_AUTH_METHOD=post
# basic | post | mobile
OIDC_PROMPT=login
OIDC_USE_PKCE=false
OIDC_HEADLESS=false
OIDC_TIMEOUT_MS=180000
# PLAYWRIGHT_PACKAGE=playwright

# USUARIO DE PRUEBA DE CIUDADANÍA
CEDULA_IDENTIDAD=12345678
CONTRASENA=tu_contrasena_aqui

# LOG_LEVEL=debug
DEBUG=true